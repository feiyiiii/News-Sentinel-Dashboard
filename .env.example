# Optional: X official API
X_BEARER_TOKEN=
X_QUERIES=from:Reuters OR from:AP OR from:BBCBreaking,Bitcoin OR Ethereum OR gold OR silver lang:en
X_MAX_RESULTS=10

# Optional: webhook delivery
WEBHOOK_URL=
WEBHOOK_FORMAT=generic-json

# Optional: WeCom / WeChat Work group robot webhook.
# Example: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WECHAT_WORK_WEBHOOK_URL=

# Optional: Alpha Vantage API key for gold/silver spot prices
ALPHA_VANTAGE_API_KEY=demo

# Optional: OpenAI/other summarizer can be added later; not required for current version
# OPENAI_API_KEY=

# Alert thresholds relative to the previous run
BTC_ALERT_PERCENT=2
ETH_ALERT_PERCENT=2
GOLD_ALERT_PERCENT=0.5
SILVER_ALERT_PERCENT=0.5

# Data/output folders
STATE_FILE=./data/state.json
REPORT_FILE=./output/latest-report.md

# Public site settings
PUBLIC_SITE_URL=https://feiyiiii.github.io/News-Sentinel-Dashboard/
GOATCOUNTER_ENDPOINT=
